generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  markets   Market[]
}

model Market {
  id                   String             @id @default(cuid())
  name                 String             @unique
  regionId             String
  requiresAnnouncement Boolean            @default(false)
  communicationType    String             @default("email")
  agentId              String?
  isActive             Boolean            @default(true)
  notes                String?
  defaultGreeting      String?
  defaultCc            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  customers            Customer[]
  emailTemplates       EmailTemplate[]
  agent                Agent?             @relation(fields: [agentId], references: [id])
  region               Region             @relation(fields: [regionId], references: [id])
  mills                Mill[]
  cycles               MonthlyCycle[]
  negotiations         NegotiationEvent[]
  pricingRules         PricingRule[]
  subgroups            Subgroup[]
  contacts             MarketContact[]
}

model Agent {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  company     String?
  createdAt   DateTime     @default(now())
  emailDrafts EmailDraft[]
  markets     Market[]
}

model MarketContact {
  id        String   @id @default(cuid())
  marketId  String
  name      String
  email     String
  role      String?
  createdAt DateTime @default(now())
  market    Market   @relation(fields: [marketId], references: [id])
}

model Customer {
  id              String              @id @default(cuid())
  name            String
  marketId        String
  subgroupId      String?
  isDirectContact Boolean             @default(false)
  contactEmail    String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  market          Market              @relation(fields: [marketId], references: [id])
  subgroup        Subgroup?           @relation(fields: [subgroupId], references: [id])
  exceptions      CustomerException[]
  emailDrafts     EmailDraft[]
  mills           Mill[]
  monthlyPrices   MonthlyPrice[]
  negotiations    NegotiationEvent[]
  orders          OrderRecord[]
}

model Subgroup {
  id           String        @id @default(cuid())
  name         String
  marketId     String
  description  String?
  createdAt    DateTime      @default(now())
  customers    Customer[]
  pricingRules PricingRule[]
  market       Market        @relation(fields: [marketId], references: [id])
}

model Mill {
  id            String         @id @default(cuid())
  name          String
  marketId      String
  customerId    String?
  location      String?
  createdAt     DateTime       @default(now())
  customer      Customer?      @relation(fields: [customerId], references: [id])
  market        Market         @relation(fields: [marketId], references: [id])
  monthlyPrices MonthlyPrice[]
  orders        OrderRecord[]
  pricingRules  PricingRule[]
}

model Fiber {
  id            String              @id @default(cuid())
  code          String              @unique
  name          String
  unit          String              @default("USD/ADT")
  createdAt     DateTime            @default(now())
  exceptions    CustomerException[]
  monthlyPrices MonthlyPrice[]
  negotiations  NegotiationEvent[]
  orders        OrderRecord[]
  pricingRules  PricingRule[]
}

model IndexDefinition {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  unit        String       @default("USD/ADT")
  createdAt   DateTime     @default(now())
  values      IndexValue[]
}

model IndexValue {
  id              String          @id @default(cuid())
  indexId         String
  month           String
  value           Decimal
  publicationDate DateTime?
  source          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  index           IndexDefinition @relation(fields: [indexId], references: [id])

  @@unique([indexId, month])
}

model PricingRule {
  id                String        @id @default(cuid())
  marketId          String
  fiberId           String
  millId            String?
  subgroupId        String?
  method            PricingMethod
  formulaExpression String?
  formulaReadable   String?
  manualPrice       Decimal?
  adjustment        Decimal?
  priority          Int           @default(99)
  activeFrom        String
  activeTo          String?
  notes             String?
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  fiber             Fiber         @relation(fields: [fiberId], references: [id])
  market            Market        @relation(fields: [marketId], references: [id])
  mill              Mill?         @relation(fields: [millId], references: [id])
  subgroup          Subgroup?     @relation(fields: [subgroupId], references: [id])

  @@index([marketId, fiberId])
}

model CustomerException {
  id              String         @id @default(cuid())
  customerId      String
  fiberId         String
  adjustmentType  AdjustmentType
  flatAdjustment  Decimal?
  formulaOverride String?
  noAnnouncement  Boolean        @default(false)
  verbalOnly      Boolean        @default(false)
  delayedStart    String?
  notes           String?
  activeFrom      String
  activeTo        String?
  createdAt       DateTime       @default(now())
  customer        Customer       @relation(fields: [customerId], references: [id])
  fiber           Fiber          @relation(fields: [fiberId], references: [id])
}

model MonthlyCycle {
  id                   String             @id @default(cuid())
  month                String
  marketId             String
  cycleStatus          CycleStatus        @default(open)
  priceStatus          PriceStatus        @default(not_started)
  commStatus           CommStatus         @default(pending)
  orderStatus          OrderStatus        @default(none)
  onHold               Boolean            @default(false)
  holdReason           String?
  holdReviewDate       DateTime?
  confirmationType     ConfirmationType?
  confirmationReceived Boolean            @default(false)
  confirmationDate     DateTime?
  confirmationRef      String?
  owner                String             @default("Andrés")
  internalNotes        String?
  externalNotes        String?
  closedAt             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  emailDrafts          EmailDraft[]
  market               Market             @relation(fields: [marketId], references: [id])
  monthlyPrices        MonthlyPrice[]
  negotiations         NegotiationEvent[]
  orders               OrderRecord[]
  snapshot             Snapshot?
  tasks                Task[]

  @@unique([month, marketId])
  @@index([month])
}

model MonthlyPrice {
  id              String         @id @default(cuid())
  cycleId         String
  marketId        String
  fiberId         String
  millId          String?
  customerId      String?
  price           Decimal?
  pricingMethod   PricingMethod?
  formulaSnapshot String?
  isOverride      Boolean        @default(false)
  overrideReason  String?
  indexSnapshot   Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  customer        Customer?      @relation(fields: [customerId], references: [id])
  cycle           MonthlyCycle   @relation(fields: [cycleId], references: [id])
  fiber           Fiber          @relation(fields: [fiberId], references: [id])
  mill            Mill?          @relation(fields: [millId], references: [id])

  @@unique([cycleId, fiberId, millId, customerId], map: "monthly_price_unique")
  @@index([cycleId])
}

model EmailTemplate {
  id              String       @id @default(cuid())
  templateKey     String
  version         Int          @default(1)
  marketId        String?
  subjectTemplate String
  bodyTemplate    String
  isActive        Boolean      @default(true)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  emailDrafts     EmailDraft[]
  market          Market?      @relation(fields: [marketId], references: [id])

  @@unique([templateKey, version])
}

model EmailDraft {
  id           String           @id @default(cuid())
  month        String
  cycleId      String
  templateId   String?
  marketId     String?
  customerId   String?
  agentId      String?
  subject      String
  body         String
  recipientsTo String
  recipientsCc String
  status       EmailDraftStatus @default(pending)
  sentAt       DateTime?
  confirmedAt  DateTime?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  agent        Agent?           @relation(fields: [agentId], references: [id])
  customer     Customer?        @relation(fields: [customerId], references: [id])
  cycle        MonthlyCycle     @relation(fields: [cycleId], references: [id])
  template     EmailTemplate?   @relation(fields: [templateId], references: [id])

  @@index([cycleId])
}

model Task {
  id         String        @id @default(cuid())
  month      String
  cycleId    String?
  marketId   String?
  customerId String?
  type       TaskType
  dueDate    DateTime?
  priority   TaskPriority  @default(med)
  status     TaskStatus    @default(open)
  notes      String?
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  cycle      MonthlyCycle? @relation(fields: [cycleId], references: [id])

  @@index([month, status])
}

model NegotiationEvent {
  id             String            @id @default(cuid())
  date           DateTime
  month          String
  marketId       String
  cycleId        String?
  customerId     String?
  fiberId        String
  discussedPrice Decimal?
  status         NegotiationStatus @default(open)
  summary        String?
  nextStep       String?
  owner          String            @default("Andrés")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  customer       Customer?         @relation(fields: [customerId], references: [id])
  cycle          MonthlyCycle?     @relation(fields: [cycleId], references: [id])
  fiber          Fiber             @relation(fields: [fiberId], references: [id])
  market         Market            @relation(fields: [marketId], references: [id])

  @@index([marketId, month])
}

model OrderRecord {
  id             String       @id @default(cuid())
  month          String
  cycleId        String
  customerId     String
  fiberId        String
  millId         String?
  volume         Decimal
  price          Decimal
  status         OrderStatus  @default(agreed)
  reference      String?
  notes          String?
  freightPerAdmt Decimal?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  customer       Customer     @relation(fields: [customerId], references: [id])
  cycle          MonthlyCycle @relation(fields: [cycleId], references: [id])
  fiber          Fiber        @relation(fields: [fiberId], references: [id])
  mill           Mill?        @relation(fields: [millId], references: [id])

  @@index([cycleId])
}

model AuditLog {
  id        String   @id @default(cuid())
  entity    String
  entityId  String
  field     String
  oldValue  String?
  newValue  String?
  changedBy String   @default("system")
  changedAt DateTime @default(now())
  marketId  String?
  month     String?
  metadata  Json?

  @@index([entity, entityId])
  @@index([changedAt])
}

model Snapshot {
  id        String       @id @default(cuid())
  cycleId   String       @unique
  month     String
  marketId  String
  payload   Json
  createdAt DateTime     @default(now())
  createdBy String       @default("system")
  cycle     MonthlyCycle @relation(fields: [cycleId], references: [id])
}

enum AdjustmentType {
  flat
  formula_override
  subgroup
  verbal_only
  no_announcement
  delayed_start
}

enum CommStatus {
  not_needed
  pending
  drafted
  sent
  confirmed
}

enum ConfirmationType {
  verbal
  email
  order
}

enum CycleStatus {
  open
  in_progress
  awaiting_confirmation
  closed
  on_hold
}

enum EmailDraftStatus {
  pending
  draft_ready
  sent
  confirmed
  corrected
  resent
}

enum NegotiationStatus {
  open
  agreed
  rejected
  pending
  withdrawn
}

enum OrderStatus {
  none
  discussed
  agreed
  ordered
  shipped
  closed
}

enum PriceStatus {
  not_started
  negotiating
  decided
  revised
}

enum PricingMethod {
  manual
  index_formula
  subgroup_adjustment
  customer_override
}

enum TaskPriority {
  high
  med
  low
}

enum TaskStatus {
  open
  in_progress
  resolved
  dismissed
}

enum TaskType {
  missing_price
  missing_index
  pending_announcement
  pending_confirmation
  hold_review
  negotiation_followup
}
